body {
  margin: 0;
  background: #111;
  color: white;
  font-family: Arial;
}

main {
  max-width: 900px;
  margin: auto;
}

section div {
  background: #1e1e1e;
  padding: 15px;
  margin: 10px 0;
  border-radius: 8px;
}

section {
  display: grid;
  gap: 10px;
}

@media (min-width: 600px) {
  section {
    grid-template-columns: 1fr 1fr;
  }
}